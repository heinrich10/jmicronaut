# @name CreatePersonInvalid
POST {{host}}/persons
Content-Type: application/json

{
  "firstName": "",
  "lastName": "Doe",
  "countryCode": "US"
}

> {%
    client.test("Create invalid person returns 400", function() {
        client.assert(response.status === 400, "Expected 400 but got " + response.status);
    });
%}

###

# @name UpdatePersonInvalid
PUT {{host}}/persons/{{personId}}
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Smith",
  "countryCode": ""
}

> {%
    client.test("Update invalid person returns 400", function() {
        client.assert(response.status === 400, "Expected 400 but got " + response.status);
    });
%}

